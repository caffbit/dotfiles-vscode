*~
*.bak
*.backup
*.orig
*.tmp

# Editor files
.idea/
*.swp
*.swo
*~

# SSH keys (keep config but ignore keys)
.ssh/*
!.ssh/config

# GPG keys
.gnupg/

# Sensitive dotfiles
.netrc
.env
.env.local
